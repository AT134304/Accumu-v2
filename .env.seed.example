# Accumu v2 — 계정 시딩 전용 환경변수 (scripts/seed-accounts.mjs가 읽음)
#
# 이 파일은 템플릿(커밋용)입니다. 실제 값을 채운 뒤 파일명을 .env.seed 로 복사해서 사용하세요.
#   cp .env.seed.example .env.seed
#
# 중요: SUPABASE_SERVICE_ROLE_KEY는 RLS를 완전히 우회하는 매우 민감한 키입니다.
#  - 절대 VITE_ 접두사를 붙이지 마세요 (붙이면 프런트 번들에 노출됩니다, ADR 0001 6장 참고)
#  - 절대 git에 커밋하지 마세요 (.env.seed는 .gitignore에 등록되어 있어야 합니다)
#  - Node 시딩 스크립트(scripts/seed-accounts.mjs) 외 다른 코드에서 import하지 마세요
#
# 값은 Supabase 대시보드 > Project Settings > API 에서 확인할 수 있습니다.

SUPABASE_URL=X
SUPABASE_SERVICE_ROLE_KEY=X
