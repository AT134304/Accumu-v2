# Accumu v2 — 저장소 공통 .gitignore
# (아직 git 저장소가 초기화되지 않았지만, 이후 git init 시 바로 적용되도록 미리 작성)

# --- 환경변수 (절대 커밋 금지: service_role 키 등 민감정보 포함) ---
.env
.env.local
.env.seed
.env.*.local

# --- Node ---
node_modules/
scripts/node_modules/
dist/
build/

# --- Supabase CLI 로컬 상태 ---
.supabase/

# --- OS / 에디터 ---
.DS_Store
*.log
